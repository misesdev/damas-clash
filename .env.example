
DB_USERNAME=mises
DB_PASSWORD=mises
DB_DATABASE=db_damas
DB_PORT=5432

REDIS_PORT=6379

JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
SENDGRID_API_KEY=your-sendgrid-api-key

CLOUDINARY_CLOUD_NAME=my-cloudinary-cloudname
CLOUDINARY_API_KEY=my-cloudinary-api-key
CLOUDINARY_API_SECRET=my-cloudinary-api-secret

NEXT_PUBLIC_API_URL=http://localhost:8080

GOOGLE_API_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

VOLTAGE_API_KEY=your-voltage-api-key

# ── Bitcoin node (externo, na rede local) ──────────────────────────────────────
# IP do seu node Bitcoin na rede interna
BITCOIN_RPC_HOST=192.168.1.x
# Porta RPC do bitcoind (padrão mainnet: 8332, testnet: 18332, signet: 38332)
BITCOIN_RPC_PORT=8332
# Credenciais do rpcauth configurado no bitcoin.conf
BITCOIN_RPC_USER=your-bitcoin-rpc-user
BITCOIN_RPC_PASSWORD=your-bitcoin-rpc-password
# Endpoints ZMQ — configure no bitcoin.conf:
#   zmqpubrawblock=tcp://0.0.0.0:28332
#   zmqpubrawtx=tcp://0.0.0.0:28333
BITCOIN_ZMQ_BLOCK=tcp://192.168.1.x:28332
BITCOIN_ZMQ_TX=tcp://192.168.1.x:28333

# ── LND ───────────────────────────────────────────────────────────────────────
# Nome visível do seu node na rede Lightning
LND_ALIAS=DamasClash

GATEWAY_API_KEY=your-secret-key-of-gateway
LND_MACAROON=your-macarron-hexadecimal
LND_REST_URL=https://lnd:8080
